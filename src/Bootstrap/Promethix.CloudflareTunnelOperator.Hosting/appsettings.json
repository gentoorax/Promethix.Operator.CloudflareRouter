{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RoutingOperator": {
    "OwnershipTag": "promethix-cloudflare-tunnel-operator",
    "ReconciliationIntervalSeconds": 30,
    "ApplyChanges": false,
    "ManagedByLabelValue": "promethix-cloudflare-tunnel-operator"
  },
  "CloudflareTunnel": {
    "AccountId": "replace-me",
    "TunnelId": "replace-me",
    "ApiToken": "replace-me",
    "OwnershipTag": "promethix-cloudflare-tunnel-operator"
  },
  "KubernetesOperator": {
    "ManagedClassName": "public",
    "ManagedTunnelName": "public-tunnel",
    "ManagedIngressClassName": "traefik-cloudflare-tunnel",
    "IngressTargetUrl": "https://traefik-cloudflare-tunnel.traefik.svc.cluster.local",
    "ManagedFinalizerName": "edge.promethix.net/tunnelpublichostname-protection",
    "OwnershipConfigMapNamespace": "cloudflare-tunnel-operator-system",
    "OwnershipConfigMapName": "promethix-cloudflare-tunnel-operator-ownership"
  },
  "AllowedHosts": "*"
}
